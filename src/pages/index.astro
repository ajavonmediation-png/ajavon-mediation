<!-- Formulaire Formspree : validation accessible + consentement + téléphone international (script chargé à la demande) -->
<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const status = document.getElementById('form-status') as HTMLElement;
  const submitBtn = form?.querySelector('.form-submit') as HTMLButtonElement;

  if (form && status && submitBtn) {
    const d = form.dataset;
    const msgRequired = d.errRequired || 'Ce champ est obligatoire.';
    const msgEmail = d.errEmail || 'Adresse email invalide.';
    const msgConsent = d.errConsent || 'Veuillez accepter la politique de confidentialité.';
    const originalLabel = submitBtn.textContent || 'Envoyer';
    const msgPhone = d.errPhone || 'Numéro de téléphone invalide.';

    // intl-tel-input : indicatif pays + formatage par pays (utils intégrés)
    const phoneInput = document.getElementById('phone') as HTMLInputElement | null;
    const phoneFull = document.getElementById('phone-full') as HTMLInputElement | null;
    const countriesSelect = document.getElementById('countries') as HTMLSelectElement | null;
    let iti: any = null;
    let userTouchedCountry = false;
    countriesSelect?.addEventListener('change', () => { userTouchedCountry = true; });

    // Initialise intl-tel-input une fois son script chargé
    const initPhone = () => {
      const itiFactory = (window as any).intlTelInput;
      if (!phoneInput || !itiFactory || iti) return;
      const itiLang = document.documentElement.lang === 'en' ? 'en' : 'fr';
      const itiUi = itiLang === 'fr' ? {
        searchPlaceholder: 'Rechercher',
        countryListAriaLabel: 'Liste des pays',
        selectedCountryAriaLabel: 'Pays sélectionné',
        clearSearchAriaLabel: 'Effacer la recherche',
        noCountrySelected: 'Aucun pays sélectionné',
        searchEmptyState: 'Aucun pays trouvé',
      } : {};

      iti = itiFactory(phoneInput, {
        initialCountry: 'fr',
        countryOrder: ['fr', 'be', 'ch', 'lu', 'ca', 'gb', 'us', 'ma', 'dz', 'tn', 'sn', 'ci'],
        countryNameLocale: itiLang,
        formatAsYouType: true,
        placeholderNumberPolicy: 'POLITE',
        uiTranslations: itiUi,
      });

      // Le choix de l'indicatif pré-remplit « Pays concernés » (modifiable ensuite)
      phoneInput.addEventListener('countrychange', () => {
        if (!iti || userTouchedCountry || !countriesSelect) return;
        const sel = iti.getSelectedCountry();
        const iso = (sel && sel.iso2 ? sel.iso2 : '').toLowerCase();
        const match = countriesSelect.querySelector('option[data-iso="' + iso + '"]') as HTMLOptionElement | null;
        if (match) countriesSelect.value = match.value;
      });
    };

    // Chargement différé : on ne télécharge le script (~300 Ko) qu'au premier
    // contact avec le champ téléphone, pour alléger le chargement initial de la page.
    let phoneScriptRequested = false;
    const loadPhoneScript = () => {
      if (phoneScriptRequested) return;
      phoneScriptRequested = true;
      if ((window as any).intlTelInput) { initPhone(); return; }
      const s = document.createElement('script');
      s.src = '/vendor/intl-tel-input/js/intlTelInputWithUtils.min.js';
      s.onload = initPhone;
      document.head.appendChild(s);
    };
    if (phoneInput) {
      phoneInput.addEventListener('focus', loadPhoneScript, { once: true });
    }

    const errorFor = (field: Element) => {
      const id = field.getAttribute('aria-describedby');
      return id ? document.getElementById(id) : null;
    };
    const setError = (field: Element, msg: string) => {
      field.setAttribute('aria-invalid', 'true');
      const el = errorFor(field);
      if (el) el.textContent = msg;
    };
    const clearError = (field: Element) => {
      field.removeAttribute('aria-invalid');
      const el = errorFor(field);
      if (el) el.textContent = '';
    };

    form.querySelectorAll('input, select, textarea').forEach((el) => {
      el.addEventListener('input', () => clearError(el));
      el.addEventListener('change', () => clearError(el));
    });

    const validate = () => {
      let firstInvalid: HTMLElement | null = null;
      const flag = (el: Element, msg: string) => {
        setError(el, msg);
        if (!firstInvalid) firstInvalid = el as HTMLElement;
      };
      form.querySelectorAll('[required]').forEach((el) => {
        const input = el as HTMLInputElement;
        if (input.type === 'checkbox') {
          if (!input.checked) flag(el, msgConsent); else clearError(el);
        } else if (input.validity.valueMissing) {
          flag(el, msgRequired);
        } else if (input.validity.typeMismatch) {
          flag(el, msgEmail);
        } else {
          clearError(el);
        }
      });
      // Téléphone facultatif : s'il est renseigné, il doit être valide pour le pays
      if (iti && phoneInput && phoneInput.value.trim() && !iti.isValidNumber()) {
        flag(phoneInput, msgPhone);
      } else if (phoneInput) {
        clearError(phoneInput);
      }
      return firstInvalid;
    };

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      status.hidden = true;
      status.className = '';

      const firstInvalid = validate();
      if (firstInvalid) {
        (firstInvalid as HTMLElement).focus();
        (firstInvalid as HTMLElement).scrollIntoView({ behavior: 'smooth', block: 'center' });
        return;
      }

      submitBtn.disabled = true;
      submitBtn.textContent = d.sending || '…';

      // Numéro complet au format international vers le champ envoyé
      if (phoneFull) {
        phoneFull.value = (phoneInput && phoneInput.value.trim())
          ? (iti ? (iti.getNumber() || phoneInput.value) : phoneInput.value)
          : '';
      }

      try {
        const response = await fetch(form.action, {
          method: 'POST',
          body: new FormData(form),
          headers: { Accept: 'application/json' },
        });
        if (response.ok) {
          status.textContent = d.success || 'Message envoyé !';
          status.className = 'success';
          form.reset();
          form.querySelectorAll('[aria-invalid]').forEach((el) => el.removeAttribute('aria-invalid'));
          if (iti) iti.setSelectedCountry('fr');
          if (phoneFull) phoneFull.value = '';
        } else {
          throw new Error('server');
        }
      } catch {
        status.textContent = d.error || 'Une erreur est survenue.';
        status.className = 'error';
      } finally {
        status.hidden = false;
        submitBtn.disabled = false;
        submitBtn.textContent = originalLabel;
        status.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      }
    });
  }
</script>
