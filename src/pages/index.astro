---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
import { useTranslations, getLocalePath } from '../i18n/index';

const lang = 'fr';
const t = useTranslations(lang);
---

<Layout
  title="AJAVON Médiation — Médiation Familiale & Internationale | La Ferté-sous-Jouarre"
  description="Cabinet spécialisé en médiation familiale nationale et internationale. Enlèvement parental, droits de visite, divorce transfrontalier. Première consultation gratuite. M. Emile Ajavon, La Ferté-sous-Jouarre."
  lang={lang}
>

<!-- ══ HERO ══ -->
<section class="hero" aria-label="Introduction">
  <div class="hero-left fade-in">
    <div class="hero-eyebrow">{t.hero.eyebrow}</div>
    <h1 set:html={t.hero.title}></h1>
    <p class="hero-desc">{t.hero.desc}</p>
    <div class="hero-actions">
      <a href="#contact" class="btn-primary">{t.hero.cta_primary}</a>
      <a href="#services" class="btn-ghost">{t.hero.cta_secondary}</a>
    </div>
  </div>

  <div class="hero-right" aria-hidden="true">
    <div class="hero-image-bg"></div>
    <div class="hero-visual">
      <div class="globe-container">
        <div class="globe-ring"></div>
        <div class="globe-ring"></div>
        <div class="globe-ring"></div>
        <div class="globe-core">
          <span class="globe-text">Médiation<br>& Conseils</span>
        </div>
        <div class="floating-tag tag-1"><Icon name="scale" size={15} /> {t.hero.tag1}</div>
        <div class="floating-tag tag-2"><Icon name="globe" size={15} /> {t.hero.tag2}</div>
        <div class="floating-tag tag-3"><Icon name="handshake" size={15} /> {t.hero.tag3}</div>
      </div>
    </div>
  </div>

  <div class="hero-stats" aria-label="Chiffres clés">
    <div class="stat">
      <div class="stat-num">{t.hero.stat1_num}</div>
      <div class="stat-label">{t.hero.stat1_label}</div>
    </div>
    <div class="stat">
      <div class="stat-num">{t.hero.stat2_num}</div>
      <div class="stat-label">{t.hero.stat2_label}</div>
    </div>
    <div class="stat">
      <div class="stat-num">{t.hero.stat3_num}</div>
      <div class="stat-label">{t.hero.stat3_label}</div>
    </div>
  </div>
</section>

<!-- ══ ABOUT ══ -->
<section class="about" id="about" aria-label={t.about.label}>
  <div class="about-left fade-in">
    <div class="section-label">{t.about.label}</div>
    <h2 set:html={t.about.title}></h2>
    <p class="about-text">{t.about.text1}</p>
    <p class="about-text">{t.about.text2}</p>
    <div class="values-list">
      <div class="value-item">
        <div class="value-icon"><Icon name="scale" size={20} /></div>
        <div class="value-text">
          <strong>{t.about.value1_title}</strong>
          <span>{t.about.value1_desc}</span>
        </div>
      </div>
      <div class="value-item">
        <div class="value-icon"><Icon name="lock" size={20} /></div>
        <div class="value-text">
          <strong>{t.about.value2_title}</strong>
          <span>{t.about.value2_desc}</span>
        </div>
      </div>
      <div class="value-item">
        <div class="value-icon"><Icon name="heart" size={20} /></div>
        <div class="value-text">
          <strong>{t.about.value3_title}</strong>
          <span>{t.about.value3_desc}</span>
        </div>
      </div>
    </div>
  </div>
  <div class="about-right fade-in">
    <div class="portrait-frame">
      <img src="/photo-ajavon.jpg" alt="M. Emile Ajavon, médiateur familial international, au Palais de Justice" class="portrait-photo" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';" />
      <div class="portrait-placeholder" role="img" aria-label={`Portrait de ${t.about.credential_name}`} style="display:none;">
        <span class="portrait-icon"><Icon name="user" size={48} /></span>
        <span class="portrait-caption">{t.about.credential_name}</span>
      </div>
      <div class="credential">
        <div class="credential-title">{t.about.credential_title}</div>
        <div class="credential-name">{t.about.credential_name}</div>
      </div>
    </div>
  </div>
</section>

<!-- ══ SERVICES ══ -->
<section class="services" id="services" aria-label={t.services.label}>
  <div class="services-header">
    <div class="section-label centered">{t.services.label}</div>
    <h2 set:html={t.services.title}></h2>
  </div>
  <div class="services-grid" role="list">
    {[
      { num: '01', title: t.services.s1_title, desc: t.services.s1_desc, tag: t.services.s1_tag },
      { num: '02', title: t.services.s2_title, desc: t.services.s2_desc, tag: t.services.s2_tag },
      { num: '03', title: t.services.s3_title, desc: t.services.s3_desc, tag: t.services.s3_tag },
      { num: '04', title: t.services.s4_title, desc: t.services.s4_desc, tag: t.services.s4_tag },
      { num: '05', title: t.services.s5_title, desc: t.services.s5_desc, tag: t.services.s5_tag },
      { num: '06', title: t.services.s6_title, desc: t.services.s6_desc, tag: t.services.s6_tag },
    ].map(s => (
      <article class="service-card fade-in" role="listitem">
        <div class="service-number" aria-hidden="true">{s.num}</div>
        <h3 class="service-title">{s.title}</h3>
        <p class="service-desc">{s.desc}</p>
        <span class="service-tag">{s.tag}</span>
      </article>
    ))}
  </div>
</section>

<!-- ══ AUTRES DOMAINES ══ -->
<section class="other-mediations" id="autres-domaines" aria-label={t.other.label}>
  <div class="other-header fade-in">
    <div class="section-label centered">{t.other.label}</div>
    <h2 set:html={t.other.title}></h2>
    <p class="other-intro">{t.other.intro}</p>
  </div>
  <div class="other-grid" role="list">
    {[
      { icon: 'shopping-cart', title: t.other.card1_title, desc: t.other.card1_desc, li: [t.other.card1_li1, t.other.card1_li2, t.other.card1_li3] },
      { icon: 'users', title: t.other.card2_title, desc: t.other.card2_desc, li: [t.other.card2_li1, t.other.card2_li2, t.other.card2_li3] },
      { icon: 'gavel', title: t.other.card3_title, desc: t.other.card3_desc, li: [t.other.card3_li1, t.other.card3_li2, t.other.card3_li3] },
      { icon: 'landmark', title: t.other.card4_title, desc: t.other.card4_desc, li: [t.other.card4_li1, t.other.card4_li2, t.other.card4_li3] },
    ].map(c => (
      <article class="other-card fade-in" role="listitem">
        <div class="other-icon"><Icon name={c.icon} size={30} /></div>
        <h3 class="other-title">{c.title}</h3>
        <p class="other-desc">{c.desc}</p>
        <ul class="other-list">
          {c.li.map(item => <li>{item}</li>)}
        </ul>
      </article>
    ))}
  </div>
</section>

<!-- ══ PROCESS ══ -->
<section class="process" id="processus" aria-label={t.process.label}>
  <div class="section-label">{t.process.label}</div>
  <h2 set:html={t.process.title}></h2>
  <ol class="process-steps">
    {[
      { num: '1', title: t.process.step1_title, desc: t.process.step1_desc },
      { num: '2', title: t.process.step2_title, desc: t.process.step2_desc },
      { num: '3', title: t.process.step3_title, desc: t.process.step3_desc },
      { num: '4', title: t.process.step4_title, desc: t.process.step4_desc },
    ].map(step => (
      <li class="step fade-in">
        <div class="step-num" aria-hidden="true">{step.num}</div>
        <h3 class="step-title">{step.title}</h3>
        <p class="step-desc">{step.desc}</p>
      </li>
    ))}
  </ol>
</section>

<!-- ══ INTERNATIONAL ══ -->
<section class="international" id="international" aria-label={t.international.label}>
  <div class="intl-content fade-in">
    <div class="section-label">{t.international.label}</div>
    <h2 set:html={t.international.title}></h2>
    <p class="intl-text">{t.international.text1}</p>
    <p class="intl-text">{t.international.text2}</p>
    <div class="countries-grid" role="list" aria-label="Pays couverts">
      {t.international.countries.map(country => (
        <div class="country-chip" role="listitem">{country}</div>
      ))}
    </div>
  </div>
  <div class="intl-visual fade-in">
    <div class="intl-card intl-card-wide">
      <div class="intl-card-icon"><Icon name="scroll-text" size={26} /></div>
      <h3 class="intl-card-title">{t.international.card1_title}</h3>
      <p class="intl-card-text">{t.international.card1_text}</p>
    </div>
    <div class="intl-card">
      <div class="intl-card-icon"><Icon name="globe" size={26} /></div>
      <h3 class="intl-card-title">{t.international.card2_title}</h3>
      <p class="intl-card-text">{t.international.card2_text}</p>
    </div>
    <div class="intl-card">
      <div class="intl-card-icon"><Icon name="languages" size={26} /></div>
      <h3 class="intl-card-title">{t.international.card3_title}</h3>
      <p class="intl-card-text">{t.international.card3_text}</p>
    </div>
  </div>
</section>

<!-- ══ LIVRE ══ -->
<section class="livre" id="livre" aria-label={t.book.label}>
  <div class="livre-inner">
    <div class="book-wrapper fade-in">
      <a href="https://librairie.publibook.com/economie-droit/15580-un-autre-regard-sur-linteret-superieur-de-lenfant-9782342374995.html" target="_blank" rel="noopener noreferrer" aria-label="Commander le livre sur Publibook">
        <img src="/livre-couverture.jpg" alt="Couverture du livre Un autre regard sur l'intérêt supérieur de l'enfant, par Amah-Émile Ajavon" class="book-img" onerror="this.style.display='none'; this.parentElement.nextElementSibling.style.display='flex';" />
      </a>
      <div class="book-placeholder" role="img" aria-label="Couverture du livre" style="display:none;">
        <Icon name="book" size={40} />
        <span class="book-placeholder-text">Un autre regard<br>sur l'intérêt<br>supérieur de l'enfant</span>
      </div>
      <div class="book-meta">
        <div class="book-meta-item"><Icon name="calendar" size={15} /> Septembre 2024</div>
        <div class="book-meta-item"><Icon name="file-text" size={15} /> 240 pages</div>
        <div class="book-meta-item"><Icon name="barcode" size={15} /> ISBN : 9782342374995</div>
        <div class="book-meta-item"><Icon name="book-open" size={15} /> Format papier & ebook</div>
      </div>
    </div>
    <div class="livre-content fade-in">
      <div class="section-label">{t.book.label}</div>
      <h2 set:html={t.book.title}></h2>
      <p class="livre-accroche">{t.book.accroche}</p>
      <div class="livre-keywords" aria-label="Mots-clés">
        {[t.book.kw1, t.book.kw2, t.book.kw3, t.book.kw4, t.book.kw5, t.book.kw6].map(kw => (
          <span class="keyword">{kw}</span>
        ))}
      </div>
      <p class="livre-desc">{t.book.desc1}</p>
      <p class="livre-desc">{t.book.desc2}</p>
      <div class="livre-prices">
        <div class="price-block">
          <div class="price-label">{t.book.format_paper}</div>
          <div class="price-amount">{t.book.price_paper}</div>
        </div>
        <div class="price-block">
          <div class="price-label">{t.book.format_ebook}</div>
          <div class="price-amount">{t.book.price_ebook}</div>
        </div>
      </div>
      <div class="livre-actions">
        <a href="https://librairie.publibook.com/economie-droit/15580-un-autre-regard-sur-linteret-superieur-de-lenfant-9782342374995.html" target="_blank" rel="noopener noreferrer" class="btn-primary">{t.book.cta_buy}</a>
        <a href="https://www.amazon.fr/autre-regard-sur-lint%C3%A9r%C3%AAt-lenfant/dp/2407010523" target="_blank" rel="noopener noreferrer" class="btn-ghost">{t.book.cta_amazon}</a>
      </div>
    </div>
  </div>
</section>

<!-- ══ TÉMOIGNAGES ══ -->
<section class="testimonials" aria-label={t.testimonials.label}>
  <div class="section-label centered">{t.testimonials.label}</div>
  <h2 set:html={t.testimonials.title}></h2>
  <div class="testimonials-grid">
    {[
      { text: t.testimonials.t1_text, author: t.testimonials.t1_author, ctx: t.testimonials.t1_context },
      { text: t.testimonials.t2_text, author: t.testimonials.t2_author, ctx: t.testimonials.t2_context },
      { text: t.testimonials.t3_text, author: t.testimonials.t3_author, ctx: t.testimonials.t3_context },
    ].map(testimonial => (
      <blockquote class="testimonial fade-in">
        <p class="testimonial-text">{testimonial.text}</p>
        <footer class="testimonial-author">
          <strong>{testimonial.author}</strong>
          <span>{testimonial.ctx}</span>
        </footer>
      </blockquote>
    ))}
  </div>
</section>

<!-- ══ CONTACT ══ -->
<section class="contact" id="contact" aria-label={t.contact.label}>
  <div class="contact-left fade-in">
    <div class="section-label">{t.contact.label}</div>
    <h2 set:html={t.contact.title}></h2>
    <p>{t.contact.intro}</p>
    <address class="contact-info">
      <div class="contact-item">
        <span class="contact-item-icon"><Icon name="map-pin" size={18} /></span>
        <span>{t.contact.address}</span>
      </div>
      <div class="contact-item">
        <span class="contact-item-icon"><Icon name="phone" size={18} /></span>
        <a href={`tel:${t.contact.phone.replace(/\s/g,'')}`}>{t.contact.phone}</a>
      </div>
      <div class="contact-item">
        <span class="contact-item-icon"><Icon name="mail" size={18} /></span>
        <a href={`mailto:${t.contact.email}`}>{t.contact.email}</a>
      </div>
      <div class="contact-item">
        <span class="contact-item-icon"><Icon name="clock" size={18} /></span>
        <span>{t.contact.hours}</span>
      </div>
    </address>
  </div>

  <div class="contact-form fade-in">
    <!-- REMPLACER mdargqov par votre ID Formspree -->
    <form id="contact-form" action="https://formspree.io/f/mdargqov" method="POST" novalidate
          data-success={t.contact.f_success}
          data-error={t.contact.f_error}
          data-sending={t.contact.f_sending}
          data-err-required={t.contact.f_err_required}
          data-err-email={t.contact.f_err_email}
          data-err-phone={t.contact.f_err_phone}
          data-err-consent={t.contact.f_err_consent}>
      <p class="form-note">{t.contact.f_required_note}</p>

      <div class="form-row">
        <div class="form-group">
          <label for="firstname">{t.contact.f_firstname} <span class="req" aria-hidden="true">*</span></label>
          <input type="text" id="firstname" name="firstname" placeholder="Marie" autocomplete="given-name" required aria-required="true" aria-describedby="firstname-error" />
          <span class="field-error" id="firstname-error" role="alert"></span>
        </div>
        <div class="form-group">
          <label for="lastname">{t.contact.f_lastname} <span class="req" aria-hidden="true">*</span></label>
          <input type="text" id="lastname" name="lastname" placeholder="Dupont" autocomplete="family-name" required aria-required="true" aria-describedby="lastname-error" />
          <span class="field-error" id="lastname-error" role="alert"></span>
        </div>
      </div>

      <div class="form-group">
        <label for="email">{t.contact.f_email} <span class="req" aria-hidden="true">*</span></label>
        <input type="email" id="email" name="email" placeholder="marie@exemple.com" autocomplete="email" required aria-required="true" aria-describedby="email-error" />
        <span class="field-error" id="email-error" role="alert"></span>
      </div>

      <div class="form-group">
        <label for="phone">{t.contact.f_phone}</label>
        <input type="tel" id="phone" autocomplete="tel" aria-describedby="phone-error" />
        <input type="hidden" name="phone" id="phone-full" />
        <span class="field-error" id="phone-error" role="alert"></span>
      </div>

      <div class="form-group">
        <label for="type">{t.contact.f_type} <span class="req" aria-hidden="true">*</span></label>
        <select id="type" name="situation" required aria-required="true" aria-describedby="type-error">
          <option value="">{t.contact.f_type_placeholder}</option>
          <option value="france">{t.contact.f_type_1}</option>
          <option value="international">{t.contact.f_type_2}</option>
          <option value="enlevement">{t.contact.f_type_3}</option>
          <option value="droits-visite">{t.contact.f_type_4}</option>
          <option value="autre">{t.contact.f_type_5}</option>
        </select>
        <span class="field-error" id="type-error" role="alert"></span>
      </div>

      <div class="form-group">
        <label for="countries">{t.contact.f_countries}</label>
        <select id="countries" name="countries">
          <option value="">— Sélectionnez (facultatif) —</option>
          <option value="France" data-iso="fr">France</option>
          <option value="Afrique du Sud" data-iso="za">Afrique du Sud</option>
          <option value="Algérie" data-iso="dz">Algérie</option>
          <option value="Allemagne" data-iso="de">Allemagne</option>
          <option value="Arabie saoudite" data-iso="sa">Arabie saoudite</option>
          <option value="Argentine" data-iso="ar">Argentine</option>
          <option value="Australie" data-iso="au">Australie</option>
          <option value="Autriche" data-iso="at">Autriche</option>
          <option value="Belgique" data-iso="be">Belgique</option>
          <option value="Bénin" data-iso="bj">Bénin</option>
          <option value="Brésil" data-iso="br">Brésil</option>
          <option value="Burkina Faso" data-iso="bf">Burkina Faso</option>
          <option value="Cameroun" data-iso="cm">Cameroun</option>
          <option value="Canada" data-iso="ca">Canada</option>
          <option value="Chine" data-iso="cn">Chine</option>
          <option value="Congo-Brazzaville" data-iso="cg">Congo-Brazzaville</option>
          <option value="Côte d'Ivoire" data-iso="ci">Côte d'Ivoire</option>
          <option value="Danemark" data-iso="dk">Danemark</option>
          <option value="Égypte" data-iso="eg">Égypte</option>
          <option value="Émirats arabes unis" data-iso="ae">Émirats arabes unis</option>
          <option value="Espagne" data-iso="es">Espagne</option>
          <option value="États-Unis" data-iso="us">États-Unis</option>
          <option value="Gabon" data-iso="ga">Gabon</option>
          <option value="Grèce" data-iso="gr">Grèce</option>
          <option value="Guinée" data-iso="gn">Guinée</option>
          <option value="Inde" data-iso="in">Inde</option>
          <option value="Irlande" data-iso="ie">Irlande</option>
          <option value="Israël" data-iso="il">Israël</option>
          <option value="Italie" data-iso="it">Italie</option>
          <option value="Japon" data-iso="jp">Japon</option>
          <option value="Liban" data-iso="lb">Liban</option>
          <option value="Luxembourg" data-iso="lu">Luxembourg</option>
          <option value="Madagascar" data-iso="mg">Madagascar</option>
          <option value="Mali" data-iso="ml">Mali</option>
          <option value="Maroc" data-iso="ma">Maroc</option>
          <option value="Maurice" data-iso="mu">Maurice</option>
          <option value="Mexique" data-iso="mx">Mexique</option>
          <option value="Niger" data-iso="ne">Niger</option>
          <option value="Norvège" data-iso="no">Norvège</option>
          <option value="Pays-Bas" data-iso="nl">Pays-Bas</option>
          <option value="Pologne" data-iso="pl">Pologne</option>
          <option value="Portugal" data-iso="pt">Portugal</option>
          <option value="Qatar" data-iso="qa">Qatar</option>
          <option value="RD Congo" data-iso="cd">RD Congo</option>
          <option value="Roumanie" data-iso="ro">Roumanie</option>
          <option value="Royaume-Uni" data-iso="gb">Royaume-Uni</option>
          <option value="Russie" data-iso="ru">Russie</option>
          <option value="Sénégal" data-iso="sn">Sénégal</option>
          <option value="Suède" data-iso="se">Suède</option>
          <option value="Suisse" data-iso="ch">Suisse</option>
          <option value="Togo" data-iso="tg">Togo</option>
          <option value="Tunisie" data-iso="tn">Tunisie</option>
          <option value="Turquie" data-iso="tr">Turquie</option>
          <option value="Autre / Plusieurs pays" data-iso="">Autre / Plusieurs pays</option>
        </select>
      </div>

      <div class="form-group">
        <label for="message">{t.contact.f_message} <span class="req" aria-hidden="true">*</span></label>
        <textarea id="message" name="message" rows="4" placeholder={t.contact.f_message_placeholder} required aria-required="true" aria-describedby="message-error"></textarea>
        <span class="field-error" id="message-error" role="alert"></span>
      </div>

      <!-- Consentement RGPD -->
      <div class="form-consent">
        <input type="checkbox" id="consent" name="consent" value="oui" required aria-required="true" aria-describedby="consent-error" />
        <label for="consent">{t.contact.f_consent_before}<a href="/politique-de-confidentialite" target="_blank" rel="noopener">{t.contact.f_consent_link}</a>{t.contact.f_consent_after} <span class="req" aria-hidden="true">*</span></label>
      </div>
      <span class="field-error consent-error" id="consent-error" role="alert"></span>

      <p class="form-privacy"><Icon name="shield-check" size={16} /> {t.contact.f_privacy_note}</p>

      <!-- Anti-spam honeypot -->
      <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off" />
      <input type="hidden" name="_subject" value="Nouvelle demande de médiation - ajavon-mediation.com" />

      <div id="form-status" role="alert" aria-live="polite" hidden></div>
      <button type="submit" class="form-submit">{t.contact.f_submit}</button>
    </form>
  </div>
</section>

</Layout>

<!-- ══ STYLES PAGE ══ -->
<style>
/* HERO */
.hero {
  min-height: 100vh;
  display: grid;
  grid-template-columns: 1fr 1fr;
  position: relative;
  overflow: hidden;
  padding-top: 80px;
}
.hero-left {
